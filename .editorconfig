root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{md,bru}]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[{,apps/**/,tenants/**/}config/**/*.{yml,yaml}]
indent_size = 4

[*.{mjs,js,ts,vue,bru}]
indent_size = 2
