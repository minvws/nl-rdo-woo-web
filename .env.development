# This file can be used for local development through docker-compose

HTTP_HOST_TO_TENANT_MAPPING="localhost:8000=minvws, localhost:8001=minvws, localhost:8443=minvws, localhost:8100=minfin, localhost:8101=minfin, localhost:8444=minfin"

APP_ENV=dev
MINVWS_APP_SECRET=THIS_IS_NOT_A_SECRET_12345678901
MINFIN_APP_SECRET=THIS_IS_NOT_A_SECRET_12345678902

MINVWS_SITE_NAME=open.minvws.nl
MINFIN_SITE_NAME=open.minfin.nl

MINVWS_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/woo_vws?serverVersion=14&charset=utf8"
MINFIN_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/woo_fin?serverVersion=14&charset=utf8"

MINVWS_HIGH_TRANSPORT_DSN=amqp://minvws:secret@rabbitmq:5672/%2fminvws/high
MINVWS_INGESTOR_TRANSPORT_DSN=amqp://minvws:secret@rabbitmq:5672/%2fminvws/ingestor
MINVWS_ESUPDATER_TRANSPORT_DSN=amqp://minvws:secret@rabbitmq:5672/%2fminvws/es_updates
MINVWS_GLOBAL_TRANSPORT_DSN=amqp://minvws:secret@rabbitmq:5672/%2fminvws/global

MINFIN_HIGH_TRANSPORT_DSN=amqp://minfin:secret@rabbitmq:5672/%2fminfin/high
MINFIN_INGESTOR_TRANSPORT_DSN=amqp://minfin:secret@rabbitmq:5672/%2fminfin/ingestor
MINFIN_ESUPDATER_TRANSPORT_DSN=amqp://minfin:secret@rabbitmq:5672/%2fminfin/es_updates
MINFIN_GLOBAL_TRANSPORT_DSN=amqp://minfin:secret@rabbitmq:5672/%2fminfin/global

# MAILER_DSN=null://null

MINVWS_RABBITMQ_STATS_URL=http://minvws:secret@rabbitmq:15672/api/overview
MINFIN_RABBITMQ_STATS_URL=http://minfin:secret@rabbitmq:15672/api/overview

ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASS=
ELASTICSEARCH_MTLS_CERT_PATH=
ELASTICSEARCH_MTLS_KEY_PATH=
ELASTICSEARCH_MTLS_CA_PATH=

TIKA_HOST=http://tika:9998

# The below values ending in be46 and e8b9d are only used for local, test, and ci envs. Generate a new one
# using "bin/console generate:database-key" for your other environments:
MINVWS_DATABASE_ENCRYPTION_KEY=314005005c42fb6849aa5d7ca12faba81643c03e71e3a590e1436a882e9fff8135237d39d99652bc7f35a39c87bd370fa4745276126b145b3d2e34f2c3ea105d424893ae82f92347393860d4fa9836fdb1933525e7de765a379bed5777402bc10cc6be46
MINFIN_DATABASE_ENCRYPTION_KEY=3140050067e7f03d2754deed92f006341baf8eeffff98a16b57ec147ddaa9281bcacd1354a0f8b874b5e5cfd5dabf9b0fca731c938f369f54c40dc3f20f61bea2506a28a5bada565c3467afca29c93ad95a9f903dbd1aeb7b80801a405b7b299910e8b9d

REDIS_URL=redis://redis:6379
REDIS_TLS_CAFILE=
REDIS_TLS_LOCAL_CERT=
REDIS_TLS_LOCAL_PK=

MINVWS_COOKIE_NAME=MINVWS_WOOPID
MINFIN_COOKIE_NAME=MINFIN_WOOPID
SESSION_COOKIE_LIFETIME=86400

MINVWS_TOTP_ISSUER=localhost
MINFIN_TOTP_ISSUER=localhost

APP_MODE=ALL
MINVWS_PUBLIC_BASE_URL=http://localhost:8000
MINFIN_PUBLIC_BASE_URL=http://localhost:8100


STORAGE_MINIO_ENDPOINT=http://minio:9000
STORAGE_MINIO_ACCESS_KEY=root
STORAGE_MINIO_SECRET_KEY=password

STORAGE_DOCUMENT_ADAPTER=aws
STORAGE_BATCH_ADAPTER=aws
STORAGE_WOO_INDEX_ADAPTER=aws
STORAGE_UPLOAD_ADAPTER=aws
STORAGE_ASSETS_ADAPTER=aws

PIWIK_ANALYTICS_ID=0

AUDITLOG_ENCRYPTION_PUB_KEY=
AUDITLOG_ENCRYPTION_PRIV_KEY=

AUDITLOG_PSR_ENCRYPTED=false
AUDITLOG_DOCTRINE_ENCRYPTED=false
AUDITLOG_RABBITMQ_ENCRYPTED=false
AUDITLOG_FILE_ENCRYPTED=false
AUDITLOG_FILE_PATH=%kernel.logs_dir%/audit.log

MINVWS_RABBITMQ_URL=amqp://minvws:secret@rabbitmq:5672/%2fminvws
MINFIN_RABBITMQ_URL=amqp://minfin:secret@rabbitmq:5672/%2fminfin

CLAM_AV_ADDRESS=tcp://clamav:3310
CLAM_AV_MAX_FILESIZE=1073741824

HAS_FEATURE_WOO_GPT=true
HAS_FEATURE_PUBLICATION_V1_API=true
MINVWS_PUBLICATION_API_SSL_USERNAME_WHITELIST="TRIAL MINVWS"
MINFIN_PUBLICATION_API_SSL_USERNAME_WHITELIST="TRIAL MINFIN"

PUBLICATION_V1_REQUEST_VALIDATION=true
PUBLICATION_V1_RESPONSE_VALIDATION=false
PUBLICATION_V1_VALIDATE_RESPONSE_ON_TERMINATE=false

TRUSTED_PROXIES=REMOTE_ADDR
ENABLE_TOOLBAR=true
