meta {
  name: Retrieves the collection of Department resources.
  type: http
  seq: 1
  tags: [
    Department
  ]
}

get {
  url: {{baseUrl}}/department
  body: none
  auth: inherit
}

params:query {
  ~cursor: 
}

script:post-response {
  const data = res.getBody();
  
  const dept = data.find(item => item.name === "E2E Test Department 1") ?? data[0];
  
  if (dept) {
    bru.setEnvVar("departmentId", dept.id);
  } else {
    console.log("Department not found");
  }
}

docs {
  Retrieves the collection of Department resources.
}

