meta {
  name: Retrieves a Advice resource.
  type: http
  seq: 2
  tags: [
    Advice
  ]
}

get {
  url: {{baseUrl}}/organisation/:organisationId/dossiers/advice/external/:dossierExternalId
  body: none
  auth: inherit
}

params:path {
  organisationId: {{organisationId}}
  dossierExternalId: {{adviceDossierExternalId}}
}

docs {
  Retrieves a Advice resource.
}

