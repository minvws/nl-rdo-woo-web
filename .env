# -----------------------------------------------------
# Environment setting (dev, prod)
# -----------------------------------------------------

# Comma separated string of <HTTP_HOST>:<tenant_id> pairs for tenant identification based on HTTP_HOST header.
HTTP_HOST_TO_TENANT_MAPPING=

###> symfony/framework-bundle ###
APP_ENV=dev
###< symfony/framework-bundle ###

APP_DEBUG=true

# -----------------------------------------------------
# Application configuration
# -----------------------------------------------------

# Unique secret for creating signatures (remember me, CSRF etc)
MINVWS_APP_SECRET=
MINFIN_APP_SECRET=

# Database at-rest encryption key (generated with "php bin/console generate:database-key")
MINVWS_DATABASE_ENCRYPTION_KEY=
MINFIN_DATABASE_ENCRYPTION_KEY=

# The name of the site. Used only for displaying purposes.
MINVWS_SITE_NAME=open.minvws.nl
MINFIN_SITE_NAME=open.minfin.nl

# -----------------------------------------------------
# External service configuration
# -----------------------------------------------------

MINVWS_DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=14&charset=utf8"
MINFIN_DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=14&charset=utf8"

# Message bus transport method
MINVWS_HIGH_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/high
MINVWS_INGESTOR_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/ingestor
MINVWS_ESUPDATER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/es_updates
MINVWS_GLOBAL_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/global
MINVWS_API_DOCUMENTS_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/api_documents

MINFIN_HIGH_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/high
MINFIN_INGESTOR_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/ingestor
MINFIN_ESUPDATER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/es_updates
MINFIN_GLOBAL_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/global
MINFIN_API_DOCUMENTS_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/api_documents

# Url to the RabbitMQ management interface for statistics
MINVWS_RABBITMQ_STATS_URL=http://guest:guest@127.0.0.1:15672
MINFIN_RABBITMQ_STATS_URL=http://guest:guest@127.0.0.1:15672

# External mailer
# MAILER_DSN=null://null

# Host of the Elasticsearch server
MINVWS_ELASTICSEARCH_HOST=http://127.0.0.1:9200
MINVWS_ELASTICSEARCH_USER=
MINVWS_ELASTICSEARCH_PASS=
MINVWS_ELASTICSEARCH_MTLS_CERT_PATH=
MINVWS_ELASTICSEARCH_MTLS_KEY_PATH=
MINVWS_ELASTICSEARCH_MTLS_CA_PATH=

MINFIN_ELASTICSEARCH_HOST=http://127.0.0.1:9200
MINFIN_ELASTICSEARCH_USER=
MINFIN_ELASTICSEARCH_PASS=
MINFIN_ELASTICSEARCH_MTLS_CERT_PATH=
MINFIN_ELASTICSEARCH_MTLS_KEY_PATH=
MINFIN_ELASTICSEARCH_MTLS_CA_PATH=

# Host of the Tika text extraction service
TIKA_HOST=http://127.0.0.1:9998

# Redis instance that is used for document content caching
MINVWS_REDIS_URL=redis://localhost:6379
MINVWS_REDIS_TLS_CAFILE=
MINVWS_REDIS_TLS_LOCAL_CERT=
MINVWS_REDIS_TLS_LOCAL_PK=

MINFIN_REDIS_URL=redis://localhost:6379
MINFIN_REDIS_TLS_CAFILE=
MINFIN_REDIS_TLS_LOCAL_CERT=
MINFIN_REDIS_TLS_LOCAL_PK=

# The name of cookie. Should start with __Host- , but cannot be prefixed
# with __Host- when running on non-TLS connections
MINVWS_COOKIE_NAME=MINVWS_WOOPID
MINFIN_COOKIE_NAME=MINFIN_WOOPID
SESSION_COOKIE_LIFETIME=86400

# Issuer of the TOTP tokens, used in 2fa for the totp URI
MINVWS_TOTP_ISSUER=localhost
MINFIN_TOTP_ISSUER=localhost

# Application mode: backend, api, frontend or all
APP_MODE=ALL

# Base URL of the application frontend (which could different from backend when APP_MODE is not ALL)
MINVWS_PUBLIC_BASE_URL=http://localhost:8000
MINFIN_PUBLIC_BASE_URL=http://localhost:8100

# -----------------------------------------------------
# Storage adapter to use
# Choose between aws or local
STORAGE_DOCUMENT_ADAPTER=local
STORAGE_BATCH_ADAPTER=local
STORAGE_WOO_INDEX_ADAPTER=local
STORAGE_UPLOAD_ADAPTER=local
STORAGE_ASSETS_ADAPTER=local

# Storage adapter configuration for AWS S3/Minio
MINVWS_STORAGE_MINIO_REGION=eu-west-1
MINVWS_STORAGE_MINIO_ENDPOINT=
MINVWS_STORAGE_MINIO_ACCESS_KEY=
MINVWS_STORAGE_MINIO_SECRET_KEY=

MINFIN_STORAGE_MINIO_REGION=eu-west-1
MINFIN_STORAGE_MINIO_ENDPOINT=
MINFIN_STORAGE_MINIO_ACCESS_KEY=
MINFIN_STORAGE_MINIO_SECRET_KEY=

# Bucket definitions for AWS S3/Minio
MINVWS_STORAGE_MINIO_UPLOAD_BUCKET=minvws-upload-bucket
MINVWS_STORAGE_MINIO_DOCUMENT_BUCKET=minvws-doc-bucket
MINVWS_STORAGE_MINIO_BATCH_BUCKET=minvws-batch-bucket
MINVWS_STORAGE_MINIO_WOO_INDEX_BUCKET=minvws-woo-index-bucket
MINVWS_STORAGE_MINIO_ASSETS_BUCKET=minvws-assets-bucket

MINFIN_STORAGE_MINIO_UPLOAD_BUCKET=minfin-upload-bucket
MINFIN_STORAGE_MINIO_DOCUMENT_BUCKET=minfin-doc-bucket
MINFIN_STORAGE_MINIO_BATCH_BUCKET=minfin-batch-bucket
MINFIN_STORAGE_MINIO_WOO_INDEX_BUCKET=minfin-woo-index-bucket
MINFIN_STORAGE_MINIO_ASSETS_BUCKET=minfin-assets-bucket

# -----------------------------------------------------
# Identification number for Piwik analytics
PIWIK_ANALYTICS_ID=0

MINVWS_RABBITMQ_URL=amqp://guest:guest@localhost:5672
MINFIN_RABBITMQ_URL=amqp://guest:guest@localhost:5672

#------------------------------------------------------
# audit logger variables
# Generate keys with "php bin/console woopie:auditlog:generate-keys"
AUDITLOG_ENCRYPTION_PUB_KEY=
AUDITLOG_ENCRYPTION_PRIV_KEY=

AUDITLOG_PSR_ENCRYPTED=false
AUDITLOG_PSR_LOG_PII=false

AUDITLOG_DOCTRINE_ENCRYPTED=false
AUDITLOG_DOCTRINE_LOG_PII=false

AUDITLOG_RABBITMQ_ENCRYPTED=false
AUDITLOG_RABBITMQ_LOG_PII=false
AUDITLOG_RABBITMQ_ROUTING_KEY=auditlog

AUDITLOG_FILE_ENCRYPTED=false
AUDITLOG_FILE_LOG_PII=false
AUDITLOG_FILE_PATH=%kernel.logs_dir%/audit.log

CLAM_AV_MAX_FILESIZE=1073741824

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

MINVWS_TRUSTED_HOSTS=^(localhost|publication-api-woo\.local)$
MINFIN_TRUSTED_HOSTS=^(localhost|publication-api-woo\.local)$

# -----------------------------------------------------
# Feature flags
HAS_FEATURE_WOO_GPT=false
HAS_FEATURE_PUBLICATION_V1_API=false

#------------------------------------------------------
# publication api
MINVWS_PUBLICATION_API_SSL_USERNAME_WHITELIST=*.minvws.nl
MINFIN_PUBLICATION_API_SSL_USERNAME_WHITELIST=*.minfin.nl
MINFIN_PUBLICATION_API_SSL_ORGANIZATION_IDENTIFIER=NTRNL-99999994
MINVWS_PUBLICATION_API_SSL_ORGANIZATION_IDENTIFIER=NTRNL-99999994
PUBLICATION_V1_REQUEST_VALIDATION=true
PUBLICATION_V1_RESPONSE_VALIDATION=true
PUBLICATION_V1_VALIDATE_RESPONSE_ON_TERMINATE=true
