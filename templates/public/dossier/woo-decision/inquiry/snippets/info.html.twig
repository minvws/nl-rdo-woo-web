{% import 'public/macros/document.html.twig' as macro %}

<div class="bg-woo-gray-100 p-6">
    <div class="woo-readable-width" data-e2e-name="inquiry-info">
    {% if dossiers.totalItemCount > 0 %}
        <p class="woo-p font-bold break-all">
            {{
                'public.inquiry.decisions_for_inquiry' | trans({
                    '{are_or_is}': 'public.global.are_or_is' | trans({ 'count': dossiers.totalItemCount }),
                    '{number_of_decisions}': 'public.inquiries.number_of_decisions' | trans({ 'count': dossiers.totalItemCount }),
                    '{inquiry_number}': inquiry.inquiryNumber,
                })
            }}:
        </p>

        {% set hasListItems = documentCount.public > 0 or documentCount.partialPublic > 0 or documentCount.alreadyPublic > 0 or documentCount.notPublic > 0 %}
        {% if hasListItems %}
        <ul class="woo-ul">
            {% if documentCount.public > 0 %}
                <li class="woo-li">
                    <span>{{ "public.inquiries.documents_made_public" | trans({ 'count': documentCount.public }) }}</span>
                    {{ macro.withdrawn_and_suspended_count(documentCount.publicWithdrawn, documentCount.publicSuspended) }}
                </li>
            {% endif %}
            {% if documentCount.partialPublic > 0 %}
                <li class="woo-li">
                    {{ "public.inquiries.documents_made_partially_public" | trans({ 'count': documentCount.partialPublic}) }}
                    {{ macro.withdrawn_and_suspended_count(documentCount.partialPublicWithdrawn, documentCount.partialPublicSuspended) }}
                </li>
            {% endif %}
            {% if documentCount.alreadyPublic > 0 %}
                <li class="woo-li">{{ "public.inquiries.documents_were_already_public" | trans({ 'count': documentCount.alreadyPublic}) }}</li>
            {% endif %}
            {% if documentCount.notPublic > 0 %}
                <li class="woo-li">{{ "public.inquiries.documents_wont_be_published" | trans({ 'count': documentCount.notPublic}) }}</li>
            {% endif %}
        </ul>
        {% endif %}

        <ul class="mt-4">
            <li>
                <a class="woo-a" href="{{ searchUrl }}" data-e2e-name="search-through-documents">{{ 'global.search_through_all' | trans }}</a>
            </li>
            <li>
                <a class="woo-a" href="{{ path('app_inquiry_inventory_download', {'token': inquiry.token}) }}" data-e2e-name="download-inventory">{{ 'public.inquiries.download_inventory' | trans({'{inquiry_number}': inquiry.inquiryNumber}) }}</a>
            </li>
        </ul>
    {% else %}
        <p class="break-all">
            {{ 'public.inquiries.no_docs_available' | trans({'inquiry_number': inquiry.inquiryNumber}) }}
        </p>
    {% endif %}
    </div>
</div>
