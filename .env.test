# define your env variables for the test env here
APP_ENV=test
MINVWS_APP_SECRET=THIS_IS_NOT_A_SECRET_12345678901
MINFIN_APP_SECRET=THIS_IS_NOT_A_SECRET_12345678902

KERNEL_CLASS='Shared\Kernel'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

MINVWS_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/woo_vws?serverVersion=14&charset=utf8"
MINFIN_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/woo_fin?serverVersion=14&charset=utf8"

MINVWS_HIGH_TRANSPORT_DSN=in-memory://
MINVWS_INGESTOR_TRANSPORT_DSN=in-memory://
MINVWS_ESUPDATER_TRANSPORT_DSN=in-memory://
MINVWS_GLOBAL_TRANSPORT_DSN=in-memory://

MINFIN_HIGH_TRANSPORT_DSN=in-memory://
MINFIN_INGESTOR_TRANSPORT_DSN=in-memory://
MINFIN_ESUPDATER_TRANSPORT_DSN=in-memory://
MINFIN_GLOBAL_TRANSPORT_DSN=in-memory://

# The below values ending in be46 and e8b9d are only used for local, test, and ci envs. Generate a new one
# using "bin/console generate:database-key" for your other environments:
MINVWS_DATABASE_ENCRYPTION_KEY=314005005c42fb6849aa5d7ca12faba81643c03e71e3a590e1436a882e9fff8135237d39d99652bc7f35a39c87bd370fa4745276126b145b3d2e34f2c3ea105d424893ae82f92347393860d4fa9836fdb1933525e7de765a379bed5777402bc10cc6be46
MINFIN_DATABASE_ENCRYPTION_KEY=3140050067e7f03d2754deed92f006341baf8eeffff98a16b57ec147ddaa9281bcacd1354a0f8b874b5e5cfd5dabf9b0fca731c938f369f54c40dc3f20f61bea2506a28a5bada565c3467afca29c93ad95a9f903dbd1aeb7b80801a405b7b299910e8b9d
# SYMFONY_DEPRECATIONS_HELPER="disabled=1"

# To prevent breaking snapshot tests because the user might have decided to change its local ports
MINVWS_PUBLIC_BASE_URL=http://localhost:8000
MINFIN_PUBLIC_BASE_URL=http://localhost:8100

STORAGE_WOO_INDEX_ADAPTER=memory

HAS_FEATURE_PUBLICATION_V1_API=true
ENABLE_UPDATE_PUBLISHED_DOSSIER_VIA_API=false
MINVWS_PUBLICATION_API_SSL_USERNAME_WHITELIST=*.minvws.nl
MINFIN_PUBLICATION_API_SSL_USERNAME_WHITELIST=*.minfin.nl
MINVWS_PUBLICATION_API_SSL_ORGANIZATION_IDENTIFIER=NTRNL-99999994
MINFIN_PUBLICATION_API_SSL_ORGANIZATION_IDENTIFIER=NTRNL-99999993
