includes:
    - phpstan-baseline.neon

parameters:
    tmpDir: ./.phpstan.cache
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true
    doctrine:
        objectManagerLoader: phpstan-doctrine-orm-bootstrap.php
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
        - apps/
        - utils/
    excludePaths:
        - src/Domain/Publication/Dossier/Type/**/*Workflow.php
        - config/packages/workflow.php
        - utils/tests/**/data/*
    level: max
    symfony:
        containerXmlPath: var/cache/minvws/shared/dev/Shared_KernelMinvwsSharedDevDebugContainer.xml
    faker:
        providerClasses:
            - Shared\Tests\Faker\GroundsFakerProvider
            - Shared\Tests\Faker\DateTimeFakerProvider
            - Shared\Tests\Faker\FileFakerProvider
            - Shared\Tests\Faker\UuidFakerProvider
    ignoreErrors:
        - identifier: missingType.generics

services:
    errorFormatter.junit:
        class: PHPStan\Command\ErrorFormatter\JUnitErrorFormatter
    -
        class: Utils\PHPStan\Rules\DontUseShouldReceiveRule
        tags:
            - phpstan.rules.rule
    -
        class: Utils\PHPStan\Rules\RequireExplicitArrayKeyTypeRule
        tags:
            - phpstan.rules.rule
