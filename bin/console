#!/usr/bin/env php
<?php

declare(strict_types=1);

use Shared\ApplicationId;
use Shared\Kernel;
use Shared\TenantId;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Input\InputOption;
use Symfony\Component\Console\Output\ConsoleOutput;
use Symfony\Component\Console\Style\SymfonyStyle;

if (! is_dir(dirname(__DIR__) . '/vendor')) {
    throw new LogicException('Dependencies are missing. Try running "composer install".');
}

if (! is_file(dirname(__DIR__) . '/vendor/autoload_runtime.php')) {
    throw new LogicException('Symfony Runtime is missing. Try running "composer require symfony/runtime".');
}

require_once dirname(__DIR__) . '/vendor/autoload_runtime.php';

return function (InputInterface $input, array $context) {
    $applicationId = ApplicationId::fromString($input->getParameterOption(['--id', '-i'], $context['APP_ID'] ?? null));
    $tenantValue = $input->getParameterOption(['--tenant', '-T'], $context['TENANT_ID'] ?? null);

    if ($tenantValue === null) {
        $io = new SymfonyStyle($input, new ConsoleOutput());
        $io->error('The --tenant (-T) option is required.');
        $io->note(sprintf('Valid values are: %s', TenantId::asString()));
        exit(1); // @phpcs:ignore Generic.PHP.ForbiddenFunctions.Found
    }

    $tenantId = TenantId::fromString($tenantValue);

    if ($tenantId === null) {
        $io = new SymfonyStyle($input, new ConsoleOutput());
        $io->error(sprintf('Invalid tenant "%s". Valid values are: %s', TenantId::asString(), $tenantValue));
        exit(1); // @phpcs:ignore Generic.PHP.ForbiddenFunctions.Found
    }

    $kernel = new Kernel($context['APP_ENV'], (bool) $context['APP_DEBUG'], $applicationId, $tenantId);

    $application = new Application($kernel);
    $application->getDefinition()->addOption(new InputOption('--id', '-i', InputOption::VALUE_REQUIRED, 'The application ID'));
    $application->getDefinition()->addOption(new InputOption('--tenant', '-T', InputOption::VALUE_REQUIRED, 'The tenant ID'));

    return $application;
};
